# Keep the build context small and never ship secrets or local data.
.env
.env.*
!.env.example

.git
.gitignore
.github

__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

.venv/
venv/
env/
ENV/

# Local data, caches, indexes, downloaded filings — regenerated at runtime.
data/
*.db
*.sqlite

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Docs aren't needed in the image
docs/
*.md
!README.md

node_modules/
