# FinSight Alpha - CLOUD environment template.
#
# Use this when running against / deploying to Google Cloud. Copy to ".env"
# (which is git-ignored) and adjust as needed:
#
#   cp .env.cloud.example .env        # macOS / Linux
#   copy .env.cloud.example .env      # Windows
#
# On Cloud Run these values are normally passed via --set-env-vars (see
# infra/gcp_commands.sh), so you only need this file for local-against-cloud runs.

# --- API / dashboard wiring -------------------------------------------------
# In the cloud, set this to the deployed FastAPI Cloud Run URL so the Streamlit
# dashboard (API Mode) talks to the live backend. Replace after first deploy.
API_BASE_URL=https://finsight-alpha-api-XXXXXXXXXX.asia-south1.run.app

MARKET_DATA_PROVIDER=yfinance

# --- Google Cloud: project & deployment ------------------------------------
GCP_PROJECT_ID=finsight-alpha-498208
PROJECT_NUMBER=771358783484
REGION=asia-south1

# --- Google Cloud: BigQuery (analytics warehouse) -------------------------
BIGQUERY_DATASET=finsight_alpha
BIGQUERY_MARKET_PRICES_TABLE=market_prices_daily
BIGQUERY_ANALYTICS_TABLE=market_analytics_daily

# --- Google Cloud: Cloud Storage (raw files / PDFs) -----------------------
GCS_BUCKET_NAME=finsight-alpha-498208-finsight-alpha-data

# Path to a service-account JSON key file. Leave EMPTY on Cloud Run - the
# attached runtime service account provides credentials automatically. Set this
# only when authenticating from your local machine.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Database (Cloud SQL / PostgreSQL, optional) ---------------------------
# For Cloud Run + Cloud SQL, use the Unix socket connection name, e.g.:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@/finsight_alpha?host=/cloudsql/finsight-alpha-498208:asia-south1:finsight-sql
DATABASE_URL=

# --- Market data provider API keys (optional) ------------------------------
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
