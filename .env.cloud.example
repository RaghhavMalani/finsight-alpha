# FinSight Alpha - cloud environment template.
#
# Use this when running against or deploying to Google Cloud. Copy to ".env"
# (which is git-ignored) and adjust as needed:
#
#   cp .env.cloud.example .env        # macOS / Linux
#   copy .env.cloud.example .env      # Windows
#
# On Cloud Run these values are normally passed via --set-env-vars by the
# scripts in infra/.

# --- Required production contract -------------------------------------------
APP_ENV=production
FINSIGHT_SECRET_KEY=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
CORS_ORIGINS=https://YOUR_FRONTEND_DOMAIN
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# --- App / API wiring -------------------------------------------------------
API_BASE_URL=https://YOUR_API_SERVICE_URL.run.app
MARKET_DATA_PROVIDER=yfinance

# --- Google Cloud: project & deployment ------------------------------------
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID
PROJECT_NUMBER=YOUR_PROJECT_NUMBER
REGION=asia-south1

# --- Google Cloud: BigQuery (analytics warehouse) --------------------------
BIGQUERY_DATASET=finsight_alpha
BIGQUERY_MARKET_PRICES_TABLE=market_prices_daily
BIGQUERY_ANALYTICS_TABLE=market_analytics_daily

# --- Google Cloud: Cloud Storage (raw files / PDFs) ------------------------
GCS_BUCKET_NAME=YOUR_BUCKET_NAME

# Path to a service-account JSON key file. Leave empty on Cloud Run; the
# attached runtime service account provides credentials automatically.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Database (Cloud SQL / PostgreSQL, required) ---------------------------
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@/finsight_alpha?host=/cloudsql/YOUR_GCP_PROJECT_ID:asia-south1:finsight-sql
DATABASE_URL=

# --- Market data provider API keys (optional) ------------------------------
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
