# FinSight Alpha - example environment file.
# Copy this file to ".env" and fill in real values. The ".env" file is git-ignored.
#
#   cp .env.example .env        # macOS / Linux
#   copy .env.example .env      # Windows
#
# Values are loaded via python-dotenv (see src/config.py).

# --- Market data provider API keys -----------------------------------------
# Alpha Vantage (https://www.alphavantage.co/support/#api-key). Optional: the
# app falls back to yfinance if this is missing.
ALPHA_VANTAGE_API_KEY=

# Polygon.io (https://polygon.io/dashboard/api-keys). Optional.
POLYGON_API_KEY=

# --- Google Cloud (Phase 1C/1D) --------------------------------------------
# Path to a service-account JSON key file for BigQuery / Cloud Storage.
GOOGLE_APPLICATION_CREDENTIALS=
# GCP project id and the Cloud Storage bucket used for exports.
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
BIGQUERY_DATASET=finsight_alpha

# --- Cloud SQL / Postgres (Phase 1D) ---------------------------------------
# SQLAlchemy connection string, e.g.
#   postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=
