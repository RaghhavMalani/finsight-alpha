# FinSight Alpha - example environment file.
# Copy this file to ".env" and fill in real values. The ".env" file is git-ignored.
#
#   cp .env.example .env        # macOS / Linux
#   copy .env.example .env      # Windows
#
# Values are loaded via python-dotenv (see src/config.py). Everything here is
# optional for local development; the app runs without cloud settings.

# --- Runtime contract --------------------------------------------------------
APP_ENV=development
# Production requires a stable random key of at least 32 characters.
FINSIGHT_SECRET_KEY=
# Comma-separated exact browser origins. Wildcards are rejected in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# Required in production until the frontend exposes tenant selection.
DEFAULT_ORGANIZATION_SLUG=finsight-internal
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# --- App / API wiring -------------------------------------------------------
# FastAPI serves the terminal UI and API from the same origin in local mode.
API_BASE_URL=http://127.0.0.1:8000

# Default market-data provider used by the service when none is specified.
MARKET_DATA_PROVIDER=yfinance

# --- Google Cloud: project & deployment ------------------------------------
# Fill these only when deploying or testing cloud integrations.
GCP_PROJECT_ID=
PROJECT_NUMBER=
REGION=asia-south1

# --- Google Cloud: BigQuery (analytics warehouse) --------------------------
BIGQUERY_DATASET=finsight_alpha
BIGQUERY_MARKET_PRICES_TABLE=market_prices_daily
BIGQUERY_ANALYTICS_TABLE=market_analytics_daily

# --- Google Cloud: Cloud Storage (raw files / PDFs) ------------------------
GCS_BUCKET_NAME=

# Path to a service-account JSON key file for BigQuery / Cloud Storage auth.
# Leave empty when running on Cloud Run; it uses the attached service account.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Database (required PostgreSQL in production; SQLite is development only) -
# SQLAlchemy URL. Example for local Postgres:
# DATABASE_URL=postgresql://username:password@localhost:5432/finsight_alpha
DATABASE_URL=

# --- Market data provider API keys (optional) ------------------------------
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=

# Optional folder containing Kaggle CSV/Parquet/JSON downloads. The API only
# inventories local files; it never uploads credentials or auto-downloads data.
KAGGLE_DATA_DIR=data/kaggle

# --- LLM providers (use any one; powers RAG, graph, and the AI agent) -------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# Other options. Local Ollama needs no key.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# Be a good SEC citizen for EDGAR fair access (optional):
# FINSIGHT_SEC_USER_AGENT=FinSight Alpha (your-email@example.com)
