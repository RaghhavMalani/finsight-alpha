# FinSight Alpha - example environment file.
# Copy this file to ".env" and fill in real values. The ".env" file is git-ignored.
#
#   cp .env.example .env        # macOS / Linux
#   copy .env.example .env      # Windows
#
# Values are loaded via python-dotenv (see src/config.py). Everything here is
# OPTIONAL for local development - the app runs without any of it set.

# --- API / dashboard wiring -------------------------------------------------
# Base URL the Streamlit dashboard uses when running in "API Mode".
API_BASE_URL=http://127.0.0.1:8000

# Default market-data provider used by the service when none is specified.
MARKET_DATA_PROVIDER=yfinance

# --- Database (Cloud SQL / PostgreSQL for app metadata) --------------------
# SQLAlchemy URL. Example for local Postgres:
DATABASE_URL=postgresql://username:password@localhost:5432/finsight_alpha

# --- Google Cloud: BigQuery (analytics warehouse) -------------------------
GCP_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=finsight_alpha
BIGQUERY_MARKET_PRICES_TABLE=market_prices_daily
BIGQUERY_ANALYTICS_TABLE=market_analytics_daily

# --- Google Cloud: Cloud Storage (raw files / PDFs) -----------------------
GCS_BUCKET_NAME=your-bucket-name

# Path to a service-account JSON key file for BigQuery / Cloud Storage auth.
GOOGLE_APPLICATION_CREDENTIALS=

# --- Market data provider API keys (optional) ------------------------------
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
